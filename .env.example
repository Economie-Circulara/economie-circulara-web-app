# === Supabase ===
# Proiectul cloud se creeaza in regiunea EU (GDPR) - vezi docs/handoff.md.
# Copiaza acest fisier in `.env.local` si completeaza valorile.
#
# Folosim noile chei API Supabase (publishable / secret), nu cele legacy (anon /
# service_role). Maparea: anon -> publishable, service_role -> secret.

# Pentru stack-ul LOCAL (`pnpm db:start`), CLI-ul afiseaza aceste valori la pornire
# (`supabase status`). Valori implicite locale uzuale:
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Pentru PROD: Dashboard > Settings > API Keys > tab "Publishable and secret API keys".
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Cheie cu privilegii (secret) - DOAR pe server, niciodata expusa in client.
SUPABASE_SECRET_KEY=

# === Playwright (optional) ===
# Cale catre Chromium pre-provizionat in mediul remote.
# PLAYWRIGHT_CHROMIUM_PATH=/opt/pw-browsers/chromium
