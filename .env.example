# === Supabase ===
# Proiectul cloud se creeaza in regiunea EU (GDPR) - vezi docs/handoff.md.
# Copiaza acest fisier in `.env.local` si completeaza valorile.

# Pentru stack-ul LOCAL (`pnpm db:start`), CLI-ul afiseaza aceste valori la pornire.
# Valori implicite locale uzuale:
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Cheie cu privilegii - DOAR pe server, niciodata expusa in client.
SUPABASE_SERVICE_ROLE_KEY=

# === Playwright (optional) ===
# Cale catre Chromium pre-provizionat in mediul remote.
# PLAYWRIGHT_CHROMIUM_PATH=/opt/pw-browsers/chromium
